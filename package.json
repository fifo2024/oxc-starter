{
    "name": "vite-oxc-scaffold",
    "private": true,
    "version": "0.1.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "preview": "vite preview",
        "lint": "oxlint src --deny-warnings",
        "lint:fix": "oxlint src --fix",
        "format": "oxfmt src",
        "format:check": "oxfmt src --check",
        "check": "npm run format:check && npm run lint"
    },
    "dependencies": {
        "react": "^19.2.4",
        "react-dom": "^19.2.4"
    },
    "devDependencies": {
        "@oxc-project/runtime": "^0.115.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.1.4",
        "oxfmt": "^0.35.0",
        "oxlint": "^1.50.0",
        "typescript": "^5.9.3",
        "vite": "^7.3.1"
    }
}
